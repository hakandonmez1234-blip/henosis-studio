# ─── Henosis Studio — Ortam Değişkenleri ───
# Bu dosyayı kopyala: cp .env.example .env
# Gerçek değerleri doldur, .env asla Git'e ekleme

# ── Supabase Auth ──
# Supabase Dashboard → Settings → API
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── AI API Anahtarları (opsiyonel — kullanıcılar kendi key'lerini girebilir) ──
# Eğer server tarafında sabitlemek istersen:
# FAL_KEY=your-fal-ai-key
# ANTHROPIC_KEY=your-anthropic-key

# ── Sunucu ──
PORT=3000
